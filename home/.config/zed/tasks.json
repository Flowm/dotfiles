// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "Worktree setup: Copy .env",
    "command": "if [ -f \"$ZED_MAIN_GIT_WORKTREE/.env\" ]; then cp \"$ZED_MAIN_GIT_WORKTREE/.env\" \"$ZED_WORKTREE_ROOT/.env\"; fi",
    "shell": {
      "program": "sh"
    },
    "reveal": "no_focus",
    "hide": "on_success",
    "hooks": ["create_worktree"]
  },
  {
    "label": "Worktree setup: Setup npm",
    "command": "if [ -f \"$ZED_WORKTREE_ROOT/package.json\" ]; then npm ci; fi",
    "shell": {
      "program": "sh"
    },
    "reveal": "no_focus",
    "hide": "on_success",
    "hooks": ["create_worktree"]
  }
]
